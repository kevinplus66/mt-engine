# MT-Engine 环境配置
# 复制此文件为 .env 并填写实际值

# ============================================
# Docker 用户 ID 设置（用于解决权限问题）
# ============================================
# 设置为主机系统的用户 ID 以匹配文件权限
# 运行 'id -u' 和 'id -g' 命令查看你的 UID/GID
# Synology NAS 用户：在 DSM 用户设置中查看你的 UID/GID
PUID=1000
PGID=1000

# 构建元数据（部署时建议 export MT_ENGINE_COMMIT="$(git rev-parse --short HEAD)"）
MT_ENGINE_COMMIT=

# Web 服务监听地址。NAS 默认局域网可访问；仅本机访问可改为 127.0.0.1
MT_ENGINE_BIND_HOST=0.0.0.0

# M-Team API Token（必需）
# 获取：M-Team 网站 -> 控制面板 -> 实验室 -> 存取令牌
MT_TOKEN=your_api_token_here

# MT-Engine API Key（非 DEBUG 部署必需，用于保护会改变状态的接口）
# 客户端或反向代理调用写入/删除/暂停/恢复等接口时，发送 Authorization: Bearer <key> 或 X-MT-ENGINE-Key
MT_ENGINE_API_KEY=
# API Key 当前请直接设置在 MT_ENGINE_API_KEY；不要提交真实值

# M-Team 用户 ID（可选，用于显示做种状态）
# 个人页面 URL 中的数字，如 userdetails.php?id=123456
MT_USER_ID=

# M-Team 网站地址（可选）
MT_SITE_URL=https://kp.m-team.cc

# 后台刷新间隔，单位秒（当前生产稳态 300 = 5分钟；不要低于 300）
REFRESH_INTERVAL=300

# FREE 自动刷新失败后的退避时间，单位秒（默认 1800 = 30分钟；M-Team 失败后暂停自动 FREE 刷新）
FREE_REFRESH_FAILURE_BACKOFF_SECONDS=1800

# PANEL 数据采集间隔，单位秒（默认 60 = 1分钟）
PANEL_COLLECT_INTERVAL=60

# HOME 媒体墙每个 source 的刷新间隔，单位秒（默认 21600 = 6小时；不要低于 21600）
# latest / movies / series / hot 会自动错峰轮转，默认约每 90 分钟刷新一个 source
MEDIA_WALL_REFRESH_INTERVAL=21600
# HOME 媒体墙 source 刷新失败后的退避时间，单位秒（默认 1800 = 30分钟；保留旧缓存并冷却后重试）
MEDIA_WALL_REFRESH_FAILURE_BACKOFF_SECONDS=1800

# HOME 媒体墙启动后首刷延迟，单位秒（默认 420 = 7分钟，用于错开 SONAR 首轮刷新）
MEDIA_WALL_STARTUP_DELAY=420

# HOME 媒体墙海报/年份/简介等元数据缓存时间，单位秒（默认 604800 = 7天）
MEDIA_WALL_METADATA_TTL=604800

# HOME 媒体墙完整轮转周期最多补充的媒体元数据次数；单个 source 使用约 1/4 预算
MEDIA_WALL_MAX_METADATA_FETCHES=40

# HOME 媒体墙每个 source 刷新时最多低频抓取的豆瓣页面海报数；只在 M-Team 元数据缺海报时使用
MEDIA_WALL_DOUBAN_POSTER_FETCHES=3

# API 请求间隔，单位秒（3-10；低于 3 秒容易触发 M-Team API 动态限流）
API_DELAY=3

# 本地调试开关。生产部署保持 false 或留空
DEBUG=false

# PushPlus 微信推送 Token（可选）
# 获取：https://www.pushplus.plus/
PUSHPLUS_TOKEN=

# qBittorrent Web UI 配置（可选，用于一键下载和 PILOT）
# Docker 部署时填写 NAS 上 qBittorrent Web UI 的可访问地址
QBITTORRENT_URL=
QBITTORRENT_USER=
QBITTORRENT_PASSWORD=

# qBittorrent 下载目录在 NAS 主机上的路径（用于 PILOT 磁盘检查）
# Synology: /volume1/downloads
# QNAP: /share/path
DOWNLOADS_PATH=/volume1/downloads

# PILOT 保存路径（容器内路径，通常为 /downloads/子目录）
PILOT_SAVE_PATH=/downloads/mt_free_farm
